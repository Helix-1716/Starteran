rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Shared chat attachments rule
    match /chat_attachments/{chatId}/{fileName} {
      // Allow read/write if the user is signed in and their ID is part of the chatId
      allow read: if request.auth != null && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid);
      allow write: if request.auth != null 
                   && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid)
                   && request.resource.size < 20 * 1024 * 1024; // 20 MB max file size
    }
  }
}
